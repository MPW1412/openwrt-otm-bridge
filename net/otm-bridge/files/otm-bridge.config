config otm-bridge 'main'
	option enabled '1'
	# Capture interface; the init script will create it if missing.
	option iface 'mon0'
	# Physical radio that hosts the monitor interface.
	option phy 'phy0'
	# EU ITS-G5 CCH = 5900 MHz / channel 180. SCH options: 5880/5890/5910 etc.
	option freq '5900'
	option bw '10MHz'
	# Broker URI; mqtts:// implies TLS on 8883.
	option broker 'mqtts://cits1.opentrafficmap.org'
	# Leave empty to derive node id from eth0 MAC (lowercase 12-hex, no separators).
	option node ''
	# 0=quiet, 1=log per 100 packets, 2=debug
	option verbose '1'

	# Local pcap mirror — second tcpdump process on the same monitor
	# interface, rotating files in tmpfs (no NAND wear).
	option capture '1'
	option capture_dir '/tmp'
	option capture_size '1'   # MB per file
	option capture_files '5'  # ring length
